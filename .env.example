# Green API (copy from ~/.claude/skills/whatsapp/scripts/.env)
GREEN_API_URL=https://api.green-api.com
GREEN_API_INSTANCE=
GREEN_API_TOKEN=

# Authorized chat: only messages from this WhatsApp group are processed.
# Group id format is "<long-number>@g.us" — find it via getContacts.
AUTHORIZED_GROUP_ID=

# Google Drive — root must be the "תיעודים" folder (the immediate parent of the plots)
DRIVE_ROOT_FOLDER_ID=1XoFd6BeTYrdARJIddRGSiUq5A4BiGOlv
# Gantt sheet that gets updated with documentation links after each upload
GANTT_SHEET_ID=1ckhUMzTLWehoOPTUCJ8f-dpwHDMrMfiY7Ombu9VY91Y
# One of: GOOGLE_CREDENTIALS_JSON (inline JSON, used in cloud) or
# GOOGLE_CREDENTIALS_PATH (path to local JSON file). Bootstrap with bootstrap_oauth.py.
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Storage
DB_PATH=./data/bot.db

# Bundle timing
BUNDLE_WINDOW_SECONDS=10
